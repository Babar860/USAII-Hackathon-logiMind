NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Express backend for Google Cloud Run
PORT=8080

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/logimind?retryWrites=true&w=majority
# Optional non-SRV fallback for environments where Node DNS cannot resolve mongodb+srv.
MONGODB_URI_DIRECT=
MONGODB_DB=logimind
# Optional for Windows/Node SRV DNS issues, comma-separated.
MONGODB_DNS_SERVERS=

# Gemini reasoning layer
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud Agent Builder handoff metadata
GOOGLE_CLOUD_AGENT_ID=
